  "performance": {
    "maxTransitionMs": 1000,
    "maxApiCallMs": 300,
    "maxMessageLoadMs": 1000,
    "maxChatLoadMs": 1000,
    "maxSendRoundtripMs": 2000,
    "longRunningStates": [
      "sidebarTranscribing",
      "sidebarSending"
    ]
  },
  "nonBlocking": {
    "rules": [
      "Chat/topic list scroll MUST update selectedIndex within maxSwipeSelectionMs without triggering a full bridge.render.",
      "Chat/topic list scroll MUST dispatch a sidebar panel partial render through bridge.enqueueSidebarPanel, NOT a full bridge.render or awaited bridge.renderSidebarPanel.",
      "The hidden native list (container 8) MUST remain non-capturing; partial renders update the app-rendered sidebar marker and panel without relying on firmware-owned selection.",
      "Rapid list swipes MUST coalesce: only the most recent panel model ever reaches the glasses. getPartialRenderStats().dropped > 0 is expected during a swipe streak.",
      "Background refreshes (polling, SSE updates) MUST NOT overwrite controller-owned sidebar selection or force an unnecessary full rebuild.",
      "Async results from stale requests (previous chat open that was abandoned) MUST be discarded silently."
    ],
    "events": [
      "render.partial.enqueue",
      "render.partial.flush"
    ]
  },
  "realMode": {
    "skipExpectations": [
      "expect.state",
      "expect.renderBodyContains"
    ],
    "trackedFields": [
      "currentScreen",
      "currentFocus",
      "asleepNoOps",
      "realModePerInputLatencies",
      "realModeRenderLatencies",
      "realModeApiTimings",
      "realModeStateTransitions"
    ],
    "reportSections": [
      "Real-mode latency buckets",
      "Asleep no-op inputs",
      "Real-mode API timings"
    ]
  },
  "blankDetection": {
    "maxUniqueColors": 5,
    "borderGreenChannelR": 0,
    "borderGreenChannelG": 255,
    "borderGreenChannelB": 0,
    "borderGreenMaxDistance": 30,
    "webviewTextLikeMin": 200
  },
