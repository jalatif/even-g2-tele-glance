    "chatCount": 5,
    "forumCount": 1,
    "topicCount": 4,
    "forumChatId": "fixture-chat-1",
    "chatIds": [
      "fixture-chat-0",
      "fixture-chat-1",
      "fixture-chat-2",
      "fixture-chat-3",
      "fixture-chat-4"
    ],
    "topicIds": [
      "fixture-topic-0",
      "fixture-topic-1",
      "fixture-topic-2",
      "fixture-topic-3"
    ],
    "chatLabels": [
      "Fixture Alpha",
      "Fixture Forum (3)",
      "Fixture Ops",
      "Fixture Research",
      "Fixture Archive"
    ],
    "topicLabels": [
      "Fixture Topic Zero",
      "Fixture Topic One (1)",
      "Fixture Topic Two (1)",
      "Fixture Topic Three (1)"
