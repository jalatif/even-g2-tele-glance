# TeleGlance backend configuration.
# Copy to .env and set TELEGLANCE_SHARED_SECRET before using the app.
# Backend URL, STT URL, Telegram API ID/hash, and Telegram session are configured
# in the TeleGlance phone Settings page, not here.

# REQUIRED: set this before using TeleGlance.
# Put the same exact value in TeleGlance Settings as Backend shared secret.
# The token is never sent over the wire; both sides use it to encrypt/decrypt
# backend API payloads. A normal string works, but a long random value is safer:
#   openssl rand -base64 32
TELEGLANCE_SHARED_SECRET=<enter-secret-token>

# Tailscale is enabled by default in code. Keep it enabled for phone/glasses
# testing over a Tailscale 100.x.x.x backend URL. Set false for LAN-only use,
# then enter http://<lan-ip>:8787 in TeleGlance Settings.
# TAILSCALE_ENABLED=true
# TAILSCALE_ENABLED=false

# Defaults already allow localhost. With Tailscale enabled, 100.64.0.0/10
# origins are also allowed automatically. Override only for custom origins.
# Override only for a custom frontend origin list.
# BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# BACKEND_CORS_ORIGIN_REGEX=

# Local Whisper STT defaults. Leave commented for the default local STT server.
# Recommended quick/default setup:
#   WHISPER_MODEL=base
#   WHISPER_DEVICE=auto
#   WHISPER_COMPUTE_TYPE=int8
#
# Faster/lighter CPU option:
#   WHISPER_MODEL=tiny
#   WHISPER_COMPUTE_TYPE=int8
#
# More accurate but slower option:
#   WHISPER_MODEL=small
#   WHISPER_COMPUTE_TYPE=int8
#
# Apple Silicon/GPU experiments may use:
#   WHISPER_DEVICE=auto
#   WHISPER_COMPUTE_TYPE=float16
#
# Advanced Whisper decoding options. Defaults are shown.
# WHISPER_BEAM_SIZE=1
# WHISPER_BEST_OF=1
# WHISPER_TEMPERATURE=0
# WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
